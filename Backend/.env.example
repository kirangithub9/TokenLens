# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ── Required ──────────────────────────────────────────────────────────────────
# URL of your Ollama server (no trailing slash)
OLLAMA_HOST=http://localhost:11434

# Model name as registered in Ollama  (e.g. gemma3:4b  or  gemma4:e4b)
OLLAMA_MODEL=gemma3:4b

# API key if your Ollama endpoint requires one; leave empty if not needed
OLLAMA_API_KEY=

# Comma-separated list of frontend origins allowed by CORS
# Local dev:   http://localhost:5173
# Production:  https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Ollama embedding model — optional ─────────────────────────────────────────
# Used for semantic PDF search (cosine similarity instead of keyword matching).
# Pull on your Ollama server: ollama pull nomic-embed-text
# Falls back to keyword search automatically if this model is not available.
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OpenAI — optional ─────────────────────────────────────────────────────────
# Required only when the user selects "GPT-4" in the model dropdown.
# Leave empty to disable OpenAI; Gemma (Ollama) still works without it.
OPENAI_API_KEY=
# Which OpenAI model to call. Recommended options:
#   gpt-4o-mini  — fast, cheap, good for demos   (default)
#   gpt-4o       — most capable, higher cost
#   gpt-4-turbo  — high capability, lower cost than gpt-4
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use local SQLite (gemma_chat.db) — fine for development.
# Set to your Supabase connection string for persistent production storage.
# Get it from: Supabase dashboard → Project Settings → Database → URI
# Example: postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Firebase Authentication ───────────────────────────────────────────────────
# Required for user auth. Get these from Firebase Console →
# Project Settings → Service accounts → Generate new private key (download JSON).
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
# Keep the surrounding quotes; \n sequences are handled automatically.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_CERT_URL=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated emails that can access the admin dashboard
ADMIN_EMAILS=you@example.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Server port (Render sets $PORT automatically; keep 8000 for local dev)
PORT=8000

# INR exchange rate used for cost display
USD_TO_INR=85.0

# Session cache backend: "in_memory" (default) or "redis"
CACHE_TYPE=in_memory
REDIS_URL=redis://localhost:6379/0
